# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL (v2.0)
DATABASE_URL=postgresql://user:password@localhost:5432/ghostchat

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Session
SESSION_TTL=600
SESSION_EXTEND=true
